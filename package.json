{
	"name": "obsidian-ragflow-sync",
	"version": "0.1.0",
	"description": "Sync Obsidian vault files into RAGFlow datasets with frontmatter-as-metadata and diff detection.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
