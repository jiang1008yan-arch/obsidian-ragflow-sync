	},
	"keywords": [
		"obsidian",
		"ragflow",
		"sync"
	],
	"author": "jiang1008yan",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^20.11.0",
		"builtin-modules": "^3.3.0",
		"esbuild": "0.20.2",
		"obsidian": "latest",
		"typescript": "^5.4.0",
		"vitest": "^1.6.0"
	}
}
